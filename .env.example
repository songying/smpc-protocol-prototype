# Environment Configuration for SMPC Protocol

# Network Configuration
NODE_ENV=development
NEXT_PUBLIC_NETWORK=localhost

# Database Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# IPFS Configuration
IPFS_API_URL=http://localhost:5001

# Blockchain Configuration - Localhost/Hardhat
LOCALHOST_RPC_URL=http://127.0.0.1:8545
LOCALHOST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Blockchain Configuration - Sepolia Testnet
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
SEPOLIA_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Blockchain Configuration - Goerli Testnet (if needed)
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_PROJECT_ID
GOERLI_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Blockchain Configuration - Mainnet (for production)
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
MAINNET_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Etherscan API (for contract verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Gas Configuration
REPORT_GAS=true
GAS_REPORTER_CURRENCY=USD
GAS_REPORTER_API_KEY=YOUR_COINMARKETCAP_API_KEY

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://yourapp.com

# Application Configuration
NEXT_PUBLIC_APP_NAME=SMPC Protocol
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=application/json,text/csv,application/octet-stream

# Smart Contract Addresses (will be populated after deployment)
NEXT_PUBLIC_DATA_REGISTRY_ADDRESS=
NEXT_PUBLIC_COMPUTING_REQUEST_ADDRESS=
NEXT_PUBLIC_FEE_MANAGEMENT_ADDRESS=
NEXT_PUBLIC_PRIVACY_COMPLIANCE_ADDRESS=
NEXT_PUBLIC_APPROVAL_MANAGER_ADDRESS=

# Development & Testing
DEBUG=smpc:*
VERBOSE_LOGGING=true

# External Services
INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY

# Monitoring & Analytics
ENABLE_ANALYTICS=false
ANALYTICS_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (if needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@smpcprotocol.com

# Deployment Configuration
DEPLOY_NETWORK=localhost
DEPLOY_GAS_PRICE=auto
DEPLOY_GAS_LIMIT=auto
VERIFY_CONTRACTS=false

# Testing Configuration
TEST_NETWORK=localhost
TEST_MNEMONIC="test test test test test test test test test test test junk"
TEST_ACCOUNT_COUNT=10

# Production Settings (set to true only in production)
PRODUCTION=false
MINIFY_CONTRACTS=false
OPTIMIZE_CONTRACTS=true

# Backup & Recovery
BACKUP_PRIVATE_KEYS=false
BACKUP_LOCATION=./backups

# Feature Flags
ENABLE_MOBILE_UI=true
ENABLE_DARK_MODE=true
ENABLE_NOTIFICATIONS=true
ENABLE_OFFLINE_MODE=false

# ── Live vertical slice (Phase 0/1) ─────────────────────────────────────────
# Backend on-chain bridge. When ENABLE_ONCHAIN=true the API mirrors data
# registration / requests / settlement onto the deployed contracts.
ENABLE_ONCHAIN=false
CONTRACT_NETWORK=localhost
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=1337
# Funded relayer key the backend signs transactions with (deployer key #0).
SERVER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Real Shamir (t=2,n=3) aggregation across the 3 compute-node containers.
ENABLE_REAL_SMPC=false
COORDINATOR_URL=http://localhost:8080

# Client-safe mirrors of the flags above (drive "Simulated" badges + tx links).
NEXT_PUBLIC_ENABLE_ONCHAIN=false
NEXT_PUBLIC_ENABLE_REAL_SMPC=false
NEXT_PUBLIC_CHAIN_NAME=SMPC Local Chain
# Base URL for tx-hash links; leave empty for a non-clickable hash chip.
NEXT_PUBLIC_EXPLORER_BASE=

# API Configuration
API_RATE_LIMIT=1000
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000
ENABLE_REDIS_CACHE=true

# Security Headers
ENABLE_CSP=true
ENABLE_HSTS=true
ENABLE_XSS_PROTECTION=true

# L2 deployment (B0 — measured on-chain gas). Set these to deploy to Arbitrum
# Sepolia and measure real L2 gas:
#   npx hardhat run scripts/deploy.cjs --network arbitrumSepolia
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
DEPLOYER_PRIVATE_KEY=