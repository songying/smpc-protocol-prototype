{
  "name": "smpc-protocol",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:frontend": "jest --config jest.config.cjs --testPathPatterns=src/",
    "test:contracts": "npx hardhat test",
    "test:all": "npm run test:contracts && npm run test",
    "blockchain:start": "ganache --host 127.0.0.1 --port 8545 --mnemonic \"test test test test test test test test test test test junk\" --accounts 10 --chain.chainId 1337",
    "contracts:compile": "npx hardhat compile",
    "contracts:deploy": "npx hardhat run scripts/deploy.ts --network localhost",
    "contracts:deploy:testnet": "npx hardhat run scripts/deploy.ts --network sepolia",
    "contracts:deploy:mainnet": "npx hardhat run scripts/deploy.ts --network mainnet",
    "contracts:verify": "npx hardhat verify --network",
    "deploy:localhost": "tsx scripts/deploy-network.ts localhost",
    "deploy:sepolia": "tsx scripts/deploy-network.ts sepolia --verify",
    "deploy:goerli": "tsx scripts/deploy-network.ts goerli --verify",
    "deploy:mainnet": "tsx scripts/deploy-network.ts mainnet --verify",
    "deploy:status": "tsx scripts/deploy-network.ts --status",
    "hardhat:node": "npx hardhat node",
    "hardhat:console": "npx hardhat console --network localhost",
    "hardhat:test": "npx hardhat test",
    "hardhat:coverage": "npx hardhat coverage",
    "gas:report": "REPORT_GAS=true npx hardhat test",
    "typechain": "npx hardhat typechain",
    "data:generate": "tsx src/scripts/generate-sample-data.ts",
    "data:generate-json": "tsx src/scripts/generate-sample-data-json.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "smpc:demo": "tsx src/scripts/run-healthcare-demo.ts"
  },
  "dependencies": {
    "@metamask/detect-provider": "^2.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@tanstack/react-query": "^5.85.3",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.10.0",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "10.4.16",
    "axios": "^1.6.2",
    "crypto-js": "^4.2.0",
    "ioredis": "^5.7.0",
    "ipfs-http-client": "^60.0.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.541.0",
    "mongodb": "^6.3.0",
    "next": "14.0.4",
    "node-fetch": "^3.3.2",
    "node-seal": "^5.1.7",
    "pino-pretty": "^13.1.1",
    "postcss": "8.4.32",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^2.12.7",
    "snarkjs": "^0.7.6",
    "tailwindcss": "3.3.6",
    "uuid": "^11.1.0",
    "viem": "^2.33.3",
    "wagmi": "^2.16.3",
    "winston": "^3.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/jest": "^30.0.0",
    "axios-mock-adapter": "^2.1.0",
    "chai": "^4.5.0",
    "dotenv": "^17.2.1",
    "ethers": "^6.15.0",
    "hardhat": "^2.26.3",
    "hardhat-deploy": "^1.0.4",
    "hardhat-gas-reporter": "^2.3.0",
    "jest": "^30.0.5",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.0.5",
    "jest-watch-typeahead": "^3.0.1",
    "msw": "^2.10.5",
    "resize-observer-polyfill": "^1.5.1",
    "solidity-coverage": "^0.8.16",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
