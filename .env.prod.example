# Production environment for docker-compose.prod.yml
# Copy to .env.prod, fill in DOMAIN, then append generated secrets:
#   cp .env.prod.example .env.prod
#   ./scripts/gen-secrets.sh >> .env.prod

# ── Public endpoint ─────────────────────────────────────────────────────────
# A domain you control, pointed at this server's public IP (DNS A record).
# Caddy will obtain a Let's Encrypt certificate automatically.
# For a bare IP / local test, use ":80" (plain HTTP) or "localhost" (self-signed).
DOMAIN=your-domain.com
ACME_EMAIL=you@your-domain.com

# Shown in tx-hash chips. Leave EXPLORER_BASE empty for a non-clickable hash.
NEXT_PUBLIC_CHAIN_NAME=SMPC Local Chain
NEXT_PUBLIC_EXPLORER_BASE=

# ── Blockchain relayer ──────────────────────────────────────────────────────
# Deployer / relayer key. The default below is the well-known Hardhat account #0
# and is SAFE only on the bundled local chain. Do NOT reuse on any public chain.
SERVER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
TEST_MNEMONIC=test test test test test test test test test test test junk

# ── Secrets (generate with scripts/gen-secrets.sh) ──────────────────────────
# JWT_SECRET=...
# ENCRYPTION_KEY=...
# SESSION_SECRET=...
